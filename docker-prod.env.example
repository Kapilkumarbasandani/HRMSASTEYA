# Asteya HRMS Production Environment Configuration
# Copy this file to .env and update the values for your environment
# Usage: cp docker-prod.env.example .env

# =============================================================================
# APPLICATION SETTINGS
# =============================================================================

# Port where the app will be accessible (default: 5555)
APP_PORT=5555

# Base URL of your installation
# Change this to your domain in production (e.g., https://hr.yourcompany.com)
APP_BASE_URL=http://localhost:5555

# =============================================================================
# DATABASE SETTINGS
# =============================================================================

# Database host
# Use "mysql" for the bundled MySQL container
# Or specify an external database host (e.g., your-db.example.com)
DB_HOST=mysql

# Database name
DB_NAME=icehrm

# Database user (used by the application)
DB_USER=icehrm

# Database password - CHANGE THIS IN PRODUCTION!
DB_PASSWORD=icehrm_secure_password

# MySQL root password (only needed for bundled MySQL container)
# Not required when using an external database
DB_ROOT_PASSWORD=icehrm_root_secure_password

# =============================================================================
# EMAIL SETTINGS (Configure via Admin > Settings > Email after login)
# =============================================================================
# Email: Mode = Swift SMTP
# Email: SMTP Host = smtp.gmail.com
# Email: SMTP Port = 587
# Email: SMTP Authentication Required = 1
# Email: SMTP User = your-email@gmail.com
# Email: SMTP Password = your-app-password
# Email: Email From = your-email@gmail.com
